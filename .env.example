# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development

# MongoDB Configuration
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB_NAME=email_classifier
MONGODB_USER=admin
MONGODB_PASSWORD=changeme123

# Google Cloud Configuration
GCP_PROJECT_ID=your-project-id
GCP_CREDENTIALS_PATH=/app/credentials/service-account-key.json
GCP_PUBSUB_TOPIC=projects/your-project-id/topics/gmail-notifications
GCP_PUBSUB_SUBSCRIPTION=projects/your-project-id/subscriptions/gmail-notifications-sub

# Gmail API Configuration
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly

# Redis Configuration (Optional)
REDIS_URL=redis://redis:6379/0

# Security
SECRET_KEY=your-secret-key-change-in-production
WEBHOOK_SECRET=your-webhook-secret-key

# Email Processing
MAX_WORKERS=4
BATCH_SIZE=10

# ========== HYBRID AI CONFIGURATION ==========

# Stage 1: Spam Detection (TF-IDF + Naive Bayes)
SPAM_MODEL_PATH=/app/models/spam_detector.pkl
SPAM_DETECTION_THRESHOLD=0.7
ENABLE_SPAM_DETECTION=true

# Stage 2: LLM Analysis (Summarization, NER, Sentiment)
# API Provider: "openai" or "claude"
LLM_API_PROVIDER=openai

# Set one of these based on your API provider:
# For OpenAI: OPENAI_API_KEY=sk-...
# For Claude: ANTHROPIC_API_KEY=sk-ant-...
LLM_API_KEY=your-llm-api-key-here

# Model selection:
# OpenAI options: gpt-3.5-turbo, gpt-4
# Claude options: claude-3-sonnet, claude-3-opus
LLM_MODEL=gpt-3.5-turbo

# LLM settings
LLM_USE_FALLBACK=true          # Use heuristics if API unavailable
LLM_TIMEOUT=30                 # Timeout in seconds
LLM_MAX_RETRIES=2

# Hybrid Classifier Configuration
ENABLE_LLMS_ANALYSIS=true       # Enable Stage 2 LLM analysis
SKIP_LLM_FOR_SPAM=true         # Skip expensive LLM calls for spam emails
CLASSIFICATION_CONFIDENCE_THRESHOLD=0.7

# Logging
LOG_LEVEL=INFO

# ========== EXAMPLE OPENAI SETUP ==========
# 1. Get API key from https://platform.openai.com/api-keys
# 2. Set LLM_API_KEY=sk-...
# 3. Set LLM_API_PROVIDER=openai
# 4. Set LLM_MODEL=gpt-3.5-turbo or gpt-4

# ========== EXAMPLE CLAUDE SETUP ==========
# 1. Get API key from https://console.anthropic.com
# 2. Set LLM_API_KEY=sk-ant-...
# 3. Set LLM_API_PROVIDER=claude
# 4. Set LLM_MODEL=claude-3-sonnet
